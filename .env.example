# ---------------------------------------------------------------------------
# Dealio environment configuration.
#
# Variables marked REQUIRED are mandatory in production — the build (and any
# request that touches a legal page or the opt-in API) will throw at module
# load if they're missing. Variables marked OPTIONAL fall back to safe
# defaults but should be set in production for full A2P 10DLC compliance.
# ---------------------------------------------------------------------------

# === Public business identity (REQUIRED in production) ===
# These are rendered into legal pages (/opt-in, /sms-terms, /privacy) and
# into the welcome / verification / help SMS bodies. Set them to the real
# operating values for Dealio Inc. — never use registered-agent addresses
# (e.g., CT Corporation's 1209 N Orange St) or unowned phone numbers.

NEXT_PUBLIC_SITE_URL=https://dealio.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@dealio.com
NEXT_PUBLIC_COMPLIANCE_EMAIL=compliance@dealio.com
NEXT_PUBLIC_SUPPORT_PHONE=+1 (555) 555-5555

NEXT_PUBLIC_BUSINESS_ADDRESS_STREET=
NEXT_PUBLIC_BUSINESS_ADDRESS_CITY=
NEXT_PUBLIC_BUSINESS_ADDRESS_REGION=
NEXT_PUBLIC_BUSINESS_ADDRESS_POSTAL=
NEXT_PUBLIC_BUSINESS_ADDRESS_COUNTRY=USA

# === Twilio (REQUIRED in production) ===
# Outbound: verification, welcome, opt-out, help, resubscribe.
# Inbound:  /api/sms-inbound validates X-Twilio-Signature using AUTH_TOKEN.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Twilio computes its signature over the EXACT public URL it POSTs to. Behind
# a proxy / load balancer this can differ from req.url, so set this to the
# canonical externally-reachable URL of the inbound webhook.
TWILIO_INBOUND_WEBHOOK_URL=https://dealio.com/api/sms-inbound

# === Opt-in durable sink (REQUIRED in production) ===
# OPT_IN_WEBHOOK_URL is the canonical place every consent event is sent.
# Must be HTTPS; localhost / metadata IPs are blocked. The bearer token is
# optional but recommended.

OPT_IN_WEBHOOK_URL=
OPT_IN_WEBHOOK_TOKEN=

# === Opt-in filesystem fallback (OPTIONAL) ===
# Used as a secondary sink (or the primary sink in dev). On serverless
# runtimes this path is usually ephemeral or read-only — rely on the
# webhook instead.
OPT_IN_LOG_PATH=

# === Origin allow-list (OPTIONAL) ===
# Comma-separated list of additional origins permitted to POST /api/sms-opt-in
# (e.g., preview deployments). Same-host requests are always allowed.
ALLOWED_ORIGIN=
